{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "allow": [
      "Bash(cmd /c run.bat)",
      "Bash(cmd /c \"chcp 65001 >nul && where claude 2>&1 && where dotnet 2>&1 && where node 2>&1\")",
      "Bash(cmd /c \"where claude & where dotnet & where node\")",
      "Bash(cmd.exe /c run.bat)",
      "Bash(where.exe claude)",
      "Bash(where.exe dotnet)",
      "Bash(where.exe node)",
      "Bash(where.exe npm)",
      "Bash(dotnet build)",
      "Bash(netstat -ano)",
      "Read(//d/dev/ai-spec-pipeline/**)",
      "Bash(xargs -r -I{} taskkill //PID {} //F)",
      "Bash(curl -s -X POST http://localhost:5001/api/run/intake -H \"Content-Type: application/json\" -d '{\"\"inputText\"\":\"\"테스트 입력\"\"}')",
      "Bash(curl -s -X POST http://localhost:5001/api/run/intake -H \"Content-Type: application/json\" -d '{\"\"inputText\"\":\"\"test input\"\"}')",
      "Bash(curl -s http://localhost:5001/api/run/f5633d60)",
      "mcp__figma__get_metadata",
      "mcp__figma__get_variable_defs",
      "mcp__figma__get_design_context",
      "mcp__figma__get_screenshot",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc -p web/tsconfig.json --noEmit)",
      "WebFetch(domain:wikidocs.net)",
      "Bash(for f in intake spec jira qa design)",
      "Bash(do echo \"=== $f ===\")",
      "Read(//d/dev/ai-spec-pipeline/prompts/**)",
      "Bash(done)",
      "Bash(/d/dev/ai-spec-pipeline/prompts/skills/intake/scripts/verify.sh:*)",
      "Bash(__NEW_LINE_7017f6bd2a95532d__ cat)",
      "Bash(/d/dev/ai-spec-pipeline/prompts/skills/spec/scripts/verify.sh:*)",
      "Bash(/d/dev/ai-spec-pipeline/prompts/skills/qa/scripts/verify.sh:*)",
      "Bash(/d/dev/ai-spec-pipeline/prompts/skills/design/scripts/verify.sh:*)",
      "Bash(/d/dev/ai-spec-pipeline/prompts/skills/jira/scripts/verify.sh:*)",
      "Bash(__NEW_LINE_7017f6bd2a95532d__ echo \"all scripts written\")",
      "Bash(mv run.bat run.win.bat)",
      "Bash(mv run.ps1 run.win.ps1)",
      "Bash(./node_modules/.bin/tsc --noEmit)",
      "Bash(node_modules/.bin/vite build)",
      "Bash(node_modules/.bin/tsc -p web/tsconfig.app.json --noEmit)",
      "Bash(ls /d/dev/ai-spec-pipeline/web/*.json)",
      "Bash(dotnet build --nologo -q)",
      "Bash(dotnet build --nologo)",
      "Bash(npx tsc -p tsconfig.app.json --noEmit)",
      "Bash(ls tsconfig*)",
      "Bash(npx vite build)",
      "Bash(node -e \":*)",
      "Read(//c/Users/Reo/.npm/**)",
      "Bash(npm install --save-dev puppeteer)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5176)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const i=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));const p=i.tool_input&&(i.tool_input.file_path||'');if(p&&p.includes('SKILL.md')){const d=new Date();const dt=d.toISOString().slice(0,10);const t=d.toTimeString().slice(0,8);const f='observations/'+dt+'.md';const line='- ['+t+'] SKILL.md 수정: '+p.replace(/.*prompts\\/skills\\//,'').replace('/SKILL.md','')+'\\n';try{require('fs').mkdirSync('observations',{recursive:true});require('fs').appendFileSync(f,line);}catch(e){}}\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
